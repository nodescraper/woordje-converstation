# Backend configuration & secrets. Copy to backend/.env and edit as needed.
# .env is gitignored — never commit real keys.

# ---- Defaults -------------------------------------------------------------
# WOORDJE_DEFAULT_LANG=nl              # target language on first load (see languages.py)
# WOORDJE_DEFAULT_PROVIDER=lmstudio-qwen
# PORT=5001
# FLASK_DEBUG=1                        # 0 disables the reloader/debugger

# ---- Local model server (LM Studio, etc.) ---------------------------------
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=qwen3.5-0.8b          # the fast "chat" model
# LMSTUDIO_REASONING_MODEL=google/gemma-4-e2b   # a model that emits a thinking channel

# ---- Cloud providers (only needed if you use them) ------------------------
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Generic OpenAI-compatible endpoint (Ollama, vLLM, OpenRouter, ...) ----
# Filled in => it appears as a selectable provider; left blank => hidden.
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=llama3.1
# OPENAI_COMPAT_LABEL=Ollama (local)
